# Copy to `.env` and fill in for local dev:
#   cp example.env .env
#
# `.env` is gitignored. The app loads it at startup via python-dotenv.
# Real OS env vars (e.g. exported in your shell or set by docker-compose)
# take precedence over values in this file.

# Which WhisperX model to load. Examples:
#   tiny | base | small | medium | large-v2 | large-v3 | large-v3-turbo
# Larger models are more accurate but slower and use more RAM.
ASR_MODEL=base

# HuggingFace token. Required for diarization (?diarize=true).
# Get one at https://huggingface.co/settings/tokens and accept the terms for
#   pyannote/segmentation-3.0
#   pyannote/speaker-diarization-3.1
# Leave blank to disable diarization entirely.
HF_TOKEN=

# Device override. Defaults to cuda if available, else cpu.
#   cuda | cpu
# DEVICE=cpu

# Compute-type override. Defaults to float16 on cuda, int8 on cpu.
#   float16 | float32 | int8 | int8_float16
# COMPUTE_TYPE=int8

# Transcription batch size. Higher = faster but more VRAM/RAM.
# BATCH_SIZE=16

# Python logging level: DEBUG | INFO | WARNING | ERROR.
# LOG_LEVEL=INFO
